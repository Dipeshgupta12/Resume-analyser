# GROQ API Key (required)
GROQ_API_KEY=your_groq_api_key_here

# Database
# SQLite (local dev) — note: on Render, data resets on restart
DATABASE_URL=sqlite:///./resume.db

# For production on Render, consider using PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/resume_db

# Application settings
MAX_FILE_SIZE_MB=5
GROQ_MODEL=llama-3.3-70b-versatile

# CORS origins (comma-separated, or * for all)
# In production, set this to your Netlify domain
CORS_ORIGINS=https://your-netlify-app.netlify.app